---
import '../styles/invitation.css';

const title = "Wedding - Cream Purple";
const description = "Undangan digital pernikahan bernuansa cream purple dengan animasi scroll halus.";
const image = "/images/decor/flower-2.webp";
---

<!DOCTYPE html>
<html lang="id" class="notranslate" translate="no">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0" />
  <meta name="color-scheme" content="light only" />
  <meta name="format-detection" content="telephone=no" />

  <title>{title}</title>
  <meta name="title" content={title} />
  <meta name="description" content={description} />

  <link rel="icon" type="image/x-icon" href="/images/decor/flower-1.webp" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- External Stylesheets -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
  <link rel="stylesheet" href="https://assets.satumomen.com/build/assets/bootstrap-vCaDZZbr.css" />
</head>

<body>
  <main id="app">
    <div id="modalOverlay" class="modal-backdrop fade" style="display: none;"></div>
    
    <!-- Loader -->
    <div id="loader" class="loader-wrapper">
      <span class="loader"></span>
    </div>

    <!-- Music Player -->
    <audio id="music" loop>
      <source src="https://assets.satumomen.com/musics/elliot-james-reay-i-think-they-call-this-love-lyrics-ql9vwz3kfqg.mp3" type="audio/mpeg" />
    </audio>

    <div id="satuMomen">
      <div class="satumomen_track">
        <ul class="satumomen_list">

          <!-- Section 1: Cover (Menggunakan Background Utama bg.jpg) -->
          <li class="container-mobile satumomen_slide satumomen_cover">
            <div class="workspace cover w-100">
              <div class="content h-100 w-100 mx-auto">
                <div class="pt-4 h-100 w-100 d-flex flex-column justify-content-center align-items-center" style="padding-bottom:80px;">
                  <div class="mt-4 mb-auto text-center animate__animated animate__fadeInDown">
                    <div class="editable color-accent" style="font-size:14.4px;color:rgb(255, 255, 255);">The Wedding Of</div>
                    <div class="editable color-accent font-latin" style="font-size:50px;line-height:1.2;color:rgb(255, 255, 255);">Nizar &amp; Aera</div>
                  </div>
                  <div class="w-100 text-center mx-auto">
                    <div class="mx-auto w-100 text-center mb-3 p-2 animate__animated animate__zoomIn" style="border-radius:.5rem;max-width:240px;background-color:rgba(255, 255, 255, 0.47);">
                      <div class="editable mb-1" style="font-size:14px;color:rgb(255, 255, 255);">Kepada Yth.<br />Bapak/Ibu/Saudara/i</div>
                      <div id="guestNameSlot" class="editable color-accent h5 font-weight-bold mb-1" style="font-size:16px;color:rgb(255, 255, 255);">Tamu Undangan</div>
                      <div id="groupNameSlot" class="editable h5" style="font-size:14.4px;color:rgb(255, 255, 255);">di Tempat</div>
                    </div>
                    <button id="btnOpenInvitation" class="btn-open-invitation btn btn-primary animate__animated animate__fadeInUp" style="font-size:14px;">Open Invitation</button>
                  </div>
                </div>
              </div>
            </div>
          </li>

          <!-- Section 2: Pembuka & Ayat -->
          <li id="mainContent" class="container-mobile satumomen_slide">
            <div class="workspace w-100">
              <div class="content h-100 w-100 mx-auto">
                <div class="h-100 w-100 d-flex flex-column justify-content-center align-items-center">
                  <div class="mb-2 editable text-center animate__animated animate__fadeInDown" style="font-size:14.4px;">Assalamuallaikum Wr.Wb</div>
                  <div class="editable text-center mb-4 animate__animated animate__fadeInDown" style="font-size:14.4px;">
                    Tanpa mengurangi rasa hormat, kami bermaksud<br />mengundang Bapak/Ibu/Saudara/i<br />pada acara resepsi pernikahan:
                  </div>
                  <div class="text-center" style="position:relative;">
                    <div class="editable color-accent h4 animate__animated animate__fadeInLeft font-accent" style="font-size:20px;">Aera Ziefara</div>
                    <div class="h4 editable text-center color-accent animate__animated animate__zoomIn font-latin" style="font-size:24px;">&amp;</div>
                    <div class="editable color-accent h4 animate__animated animate__fadeInRight font-accent" style="font-size:20px;">Muhammad Nizar</div>
                  </div>
                  
                  <!-- Bunga 1 (Wave Animation) -->
                  <div class="wave-left my-3 mx-auto image-editable justify-content-center animate__animated animate__zoomIn" style="width:20%;height:auto;">
                    <img src="/images/decor/flower-1.webp" alt="flower" class="w-100 h-auto" style="pointer-events: none;" loading="lazy" decoding="async" />
                  </div>

                  <div class="text-center animate__animated animate__fadeInUp">
                    <div class="editable quotes mb-3" style="font-size:14.4px;">
                      Dan di antara tanda-tanda (kebesaran)-Nya ialah Dia menciptakan pasangan-pasangan untukmu dari jenismu sendiri, agar kamu cenderung dan merasa tenteram kepadanya, dan Dia menjadikan di antaramu rasa kasih dan sayang. Sungguh, pada yang demikian itu benar-benar terdapat tanda-tanda (kebesaran Allah) bagi kaum yang berpikir.
                    </div>
                    <div class="editable" style="font-size:14.4px;">(Ar-Rum : 21)</div>
                  </div>
                </div>
              </div>
            </div>
          </li>

          <!-- Section 3: Mempelai -->
          <li class="container-mobile satumomen_slide">
            <div class="workspace w-100">
              <div class="content h-100 w-100 mx-auto" style="position: relative;">
                <img src="/images/decor/flower-bm.webp" style="pointer-events: none; position: absolute; left: 0; top: 0; right: 0; bottom: 0; width: 100%; opacity: 0.3;" alt="flower motif" loading="lazy" decoding="async" />
                <div class="h-100 w-100 d-flex flex-column justify-content-center align-items-center">
                  <div class="position-relative mb-4 mx-auto image-editable justify-content-center animate__animated animate__zoomIn" style="width:70%;height:auto;">
                    <!-- Bunga 2 (Wave Left) -->
                    <div style="width:50%;position:absolute;left:-27%;top:-12%;" class="wave-left">
                      <img src="/images/decor/flower-2.webp" alt="flower" class="w-100 h-auto" style="pointer-events: none; transform-origin: bottom center;" loading="lazy" decoding="async" />
                    </div>
                    <!-- Bunga 3 (Wave Right) -->
                    <div style="width:50%;position:absolute;right:-27%;bottom:-3%;" class="wave-right">
                      <img src="/images/decor/flower-3.webp" alt="flower" class="w-100 h-auto" style="pointer-events: none; transform-origin: bottom center;" loading="lazy" decoding="async" />
                    </div>
                    <div class="w-100 position-relative" style="overflow:hidden;border-radius:0.5rem;height:180px;border:4px solid var(--inv-border);">
                      <img src="/images/bride.jpg" alt="couple" class="w-100 h-100" style="object-fit: cover;" loading="lazy" decoding="async" />
                    </div>
                  </div>
                  <div class="text-center mb-4" style="position:relative;">
                    <div class="editable color-accent h4 mb-2 animate__animated animate__fadeInLeft font-accent" style="font-size:20px;">Aera Ziefara</div>
                    <div class="editable animate__animated animate__zoomIn" style="font-size:14.4px;">Putri dari pasangan<br />Bapak Ir. H. Sumari &amp;<br />Ibu Hj. Ngatmini, S.E</div>
                    <a href="https://instagram.com/" class="mt-2 link btn btn-primary btn-sm animate__animated animate__fadeInUp" rel="nofollow noreferrer noopener" target="_blank">@instagram</a>
                  </div>
                  <div class="text-center" style="position:relative;">
                    <div class="editable color-accent h4 mb-2 animate__animated animate__fadeInRight font-accent" style="font-size:20px;">Muhammad Nizar</div>
                    <div class="editable animate__animated animate__zoomIn" style="font-size:14.4px;">Putra dari pasangan<br />Bapak Ir. Junaidi, S. IP (Alm) &amp;<br />Ibu Restu Ningrawati</div>
                    <a href="https://instagram.com/" class="mt-2 link btn btn-primary btn-sm animate__animated animate__fadeInUp" rel="nofollow noreferrer noopener" target="_blank">@instagram</a>
                  </div>
                </div>
              </div>
            </div>
          </li>

          <!-- Section 4: Waktu & Tanggal -->
          <li class="container-mobile satumomen_slide">
            <div class="workspace w-100">
              <div class="content h-100 w-100 mx-auto">
                <div class="position-relative h-100 w-100 d-flex flex-column justify-content-center align-items-center">
                  <div style="width:35%;position:absolute;left:-20%;top:-3%;" class="wave-left">
                    <img src="/images/decor/flower-6.webp" alt="flower" class="w-100 h-auto" style="pointer-events: none;transform-origin: bottom center;" loading="lazy" decoding="async" />
                  </div>
                  <div style="width:35%;position:absolute;right:-20%;bottom:-3%;transform:scaleX(-1);" class="wave-left">
                    <img src="/images/decor/flower-6.webp" alt="flower" class="w-100 h-auto" style="pointer-events: none;transform-origin: bottom center;" loading="lazy" decoding="async" />
                  </div>
                  <div>
                    <div>
                      <div class="editable text-center color-accent h4 animate__animated animate__fadeInLeft font-accent" style="font-size:40px;">Akad</div>
                      <div class="editable text-center animate__animated animate__fadeInDown" style="font-size:14.4px;">Jumat, 24 Januari 2025</div>
                      <div class="editable text-center animate__animated animate__fadeInDown" style="font-size:14.4px;">09.00 - Selesai</div>
                      <div class="editable text-center animate__animated animate__fadeInDown" style="font-size:14.4px;">di Kediaman Mempelai Wanita</div>
                    </div>
                    <div class="my-3 mx-auto image-editable justify-content-center animate__animated animate__zoomIn" style="width:30%;height:auto;">
                      <img src="/images/decor/flower-4.webp" alt="flower" class="w-100 h-auto" style="pointer-events: none;" loading="lazy" decoding="async" />
                    </div>
                    <div>
                      <div class="editable text-center color-accent h4 animate__animated animate__fadeInRight font-accent" style="font-size:40px;">Resepsi</div>
                      <div class="editable text-center animate__animated animate__fadeInUp" style="font-size:14.4px;">Sabtu, 25 Januari 2025</div>
                      <div class="editable text-center animate__animated animate__fadeInUp" style="font-size:14.4px;">11.00 - Selesai</div>
                      <div class="editable text-center animate__animated animate__fadeInUp" style="font-size:14.4px;">Hotel Novotel Pekanbaru</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </li>

          <!-- Section 5: Galeri -->
          <li class="container-mobile satumomen_slide">
            <div class="workspace w-100">
              <div class="content h-100 w-100 mx-auto">
                <div class="position-relative w-100 d-flex flex-column justify-content-center align-items-center">
                  <div class="w-100">
                    <div class="text-center mb-4 animate__animated animate__fadeInDown color-accent">
                      <div class="h4 mb-2 editable font-accent" style="font-size:32px;">Galeri</div>
                    </div>
                    <div class="form-row">
                      <div class="col-6">
                        <div class="mb-2 w-100 animate__animated animate__zoomIn">
                          <div style="overflow:hidden;width:100%;height:120px;">
                            <img src="/images/gallery/1.jpg" style="width: 100%;height: 100%;object-fit: cover;" class="lightbox" alt="gallery-1" loading="lazy" decoding="async" />
                          </div>
                        </div>
                        <div class="mb-2 w-100 animate__animated animate__zoomIn">
                          <div style="overflow:hidden;width:100%;height:280px;">
                            <img src="/images/gallery/2.jpg" style="width: 100%;height: 100%;object-fit: cover;" class="lightbox" alt="gallery-2" loading="lazy" decoding="async" />
                          </div>
                        </div>
                        <div class="w-100 animate__animated animate__zoomIn">
                          <div style="overflow:hidden;width:100%;height:260px;">
                            <img src="/images/gallery/3.jpg" style="width: 100%;height: 100%;object-fit: cover;" class="lightbox" alt="gallery-3" loading="lazy" decoding="async" />
                          </div>
                        </div>
                      </div>
                      <div class="col-6">
                        <div class="mb-2 w-100 animate__animated animate__zoomIn">
                          <div style="overflow:hidden;width:100%;height:280px;">
                            <img src="/images/gallery/4.jpg" style="width: 100%;height: 100%;object-fit: cover;" class="lightbox" alt="gallery-4" loading="lazy" decoding="async" />
                          </div>
                        </div>
                        <div class="mb-2 w-100 animate__animated animate__zoomIn">
                          <div style="overflow:hidden;width:100%;height:120px;">
                            <img src="/images/gallery/5.jpg" style="width: 100%;height: 100%;object-fit: cover;" class="lightbox" alt="gallery-5" loading="lazy" decoding="async" />
                          </div>
                        </div>
                        <div class="w-100 animate__animated animate__zoomIn">
                          <div style="overflow:hidden;width:100%;height:260px;">
                            <img src="/images/gallery/6.jpg" style="width: 100%;height: 100%;object-fit: cover;" class="lightbox" alt="gallery-6" loading="lazy" decoding="async" />
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </li>

          <!-- Section 6: RSVP -->
          <li class="container-mobile satumomen_slide">
            <div class="workspace w-100">
              <div class="content h-100 w-100 mx-auto">
                <div class="d-flex justify-content-center align-items-center" style="height:100%;">
                  <div style="width:100%;">
                    <div>
                      <div class="animate__animated animate__fadeInRight">
                        <div class="image-editable" style="width:248px;height:195px;margin:auto;overflow:hidden;transform:translate(15px, 24px) rotate(356deg);border:4px solid var(--inv-border);">
                          <img src="/images/bride.jpg" style="width: 100%; height: 100%; object-fit: cover" alt="bride" loading="lazy" decoding="async" />
                        </div>
                      </div>
                      <div class="animate__animated animate__fadeInLeft">
                        <div class="image-editable" style="width:248px;height:195px;margin:auto;overflow:hidden;margin-bottom:20px;transform:translate(-7px, 0px) rotate(2deg);border:4px solid var(--inv-border);">
                          <img src="/images/groom.jpg" style="width: 100%; height: 100%; object-fit: cover" alt="groom" loading="lazy" decoding="async" />
                        </div>
                      </div>
                      <div class="text-center">
                        <div class="editable mb-4 animate__animated animate__fadeInUp" style="font-size:14.4px;">
                          Kirim ucapan untuk mempelai<br />dan konfirmasi kehadiran
                        </div>
                        <button id="btnOpenRsvpModal" class="btn-rsvp btn btn-primary mb-4 animate__animated animate__fadeInUp">
                          Kirim Ucapan RSVP
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </li>

          <!-- Section 7: Gift / Hadiah -->
          <li class="container-mobile satumomen_slide">
            <div class="workspace w-100">
              <div class="content h-100 w-100 mx-auto">
                <div class="h-100 d-flex justify-content-center align-items-center">
                  <div class="w-100 text-center">
                    <div class="mx-auto image-editable justify-content-center animate__animated animate__zoomIn" style="width:30%;height:auto;">
                      <img src="/images/decor/gift-icon.webp" alt="gift" class="w-100 h-auto" loading="lazy" decoding="async" />
                    </div>
                    <div class="editable mb-4 animate__animated animate__fadeInDown" style="font-size:14.4px;">
                      Terima kasih telah menambah semangat kegembiraan pernikahan kami dengan kehadiran dan hadiah indah Anda.
                    </div>
                    <div class="mt-3 p-4 rounded animate__animated animate__zoomIn" style="border:1px solid var(--inv-border); background-color: rgba(255,255,255,0.6);">
                      <div class="d-flex">
                        <div class="mx-auto">
                          <div class="d-flex align-items-center mb-3">
                            <div style="width:80px;height:50px;overflow:hidden;" class="image-editable bg-white rounded">
                              <img src="/images/bank/bca.webp" style="width: 100%;height: 100%;object-fit: contain;" alt="BCA" loading="lazy" decoding="async" />
                            </div>
                            <div class="text-left pl-2">
                              <div class="editable account-number font-weight-bold h5 mb-0">12345678</div>
                              <div class="editable" style="font-size:14.4px;">BCA : Atas Nama Rekening</div>
                            </div>
                          </div>
                          <div class="d-flex align-items-center">
                            <div style="width:80px;height:50px;overflow:hidden;" class="image-editable bg-white rounded">
                              <img src="/images/bank/bni.webp" style="width: 100%;height: 100%;object-fit: contain;" alt="BNI" loading="lazy" decoding="async" />
                            </div>
                            <div class="text-left pl-2">
                              <div class="editable account-number font-weight-bold h5 mb-0" style="font-size:18px;">12345678</div>
                              <div class="editable" style="font-size:14.4px;">BNI : Atas Nama</div>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </li>

          <!-- Section 8: Penutup -->
          <li class="container-mobile satumomen_slide">
            <div class="workspace w-100">
              <div class="content h-100 w-100 mx-auto">
                <div class="position-relative watermark d-flex flex-column justify-content-center h-100">
                  <div style="width:35%;position:absolute;left:-14%;bottom:40%;" class="wave-left">
                    <img src="/images/decor/flower-5.webp" alt="flower" class="w-100 h-auto" style="pointer-events: none;transform-origin: bottom center;" loading="lazy" decoding="async" />
                  </div>
                  <div style="width:35%;position:absolute;right:-14%;bottom:40%;transform:scaleX(-1);" class="wave-left">
                    <img src="/images/decor/flower-5.webp" alt="flower" class="w-100 h-auto" style="pointer-events: none;transform-origin: bottom center;" loading="lazy" decoding="async" />
                  </div>
                  <div style="width:calc(100% + 60px);position:absolute;left:-30px;right:-30px;bottom:-30px;" class="animate__animated animate__fadeInUp">
                    <img src="/images/decor/building-motif.webp" alt="motif" class="w-100 h-auto" style="pointer-events: none;" loading="lazy" decoding="async" />
                  </div>
                  <div class="position-relative">
                    <div class="w-100">
                      <div class="text-center">
                        <div class="editable mb-2 animate__animated animate__fadeInDown" style="font-size:14.4px;">
                          Merupakan suatu kehormatan dan<br />kebahagiaan bagi kami apabila<br />Bapak/Ibu/Saudara/i berkenan hadir<br />untuk memberikan do’a restu.
                        </div>
                        <div class="editable mb-4 animate__animated animate__fadeInDown" style="font-size:14.4px;">
                          Atas kehadiran dan do’a restunya<br />kami ucapkan terima kasih.
                        </div>
                        <div class="mb-2 editable animate__animated animate__fadeInDown">Kami yang berbahagia<br /></div>
                        <div class="text-center" style="position:relative;">
                          <div class="editable color-accent h4 animate__animated animate__fadeInLeft font-accent" style="font-size:32px;">Aera</div>
                          <div class="h4 editable text-center color-accent animate__animated animate__zoomIn font-latin" style="font-size:24px;">&amp;</div>
                          <div class="editable color-accent h4 animate__animated animate__fadeInRight font-accent" style="font-size:32px;">Nizar</div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </li>

        </ul>
      </div>
    </div>

    <!-- Floating Action Buttons -->
    <div class="floating-action d-flex align-items-end flex-column">
      <button id="btnQrModal" class="btn btn-float">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 256 256">
          <rect x="40" y="40" width="80" height="80" rx="16"></rect>
          <rect x="40" y="136" width="80" height="80" rx="16"></rect>
          <rect x="136" y="40" width="80" height="80" rx="16"></rect>
        </svg>
      </button>
      <button id="btnMusic" class="btn btn-float">
        <svg class="play" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 256 256">
          <path d="M184,152V104a8,8,0,0,1,16,0v48a8,8,0,0,1-16,0Zm40-72a8,8,0,0,0-8,8v80a8,8,0,0,0,16,0V88A8,8,0,0,0,224,80ZM53.92,34.62A8,8,0,1,0,42.08,45.38L73.55,80H32A16,16,0,0,0,16,96v64a16,16,0,0,0,16,16H77.25l69.84,54.31A8,8,0,0,0,160,224V175.09l42.08,46.29a8,8,0,1,0,11.84-10.76Zm92.16,77.59A8,8,0,0,0,160,106.83V32a8,8,0,0,0-12.91-6.31l-39.85,31a8,8,0,0,0-1,11.7Z"></path>
        </svg>
      </button>
    </div>

    <!-- Modal QR Code -->
    <div class="modal fade" id="qrModal" tabindex="-1" role="dialog" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content p-4 text-center">
          <h5>Kode QR Tamu</h5>
          <div class="my-3 mx-auto" style="width: 180px; height: 180px; background: #fff; padding: 10px; border-radius: 8px; border: 1px solid #ccc;">
            <svg xmlns="http://www.w3.org/2000/svg" version="1.1" width="160" height="160" viewBox="0 0 180 180">
              <rect x="0" y="0" width="180" height="180" fill="#ffffff"/>
              <g transform="scale(8.571)">
                <path d="M0 0L0 7L7 7L7 0ZM1 1L1 6L6 6L6 1ZM2 2L2 5L5 5L5 2ZM14 0L14 7L21 7L21 0ZM15 1L15 6L20 6L20 1ZM16 2L16 5L19 5L19 2ZM0 14L0 21L7 21L7 14ZM1 15L1 20L6 20L6 15ZM2 16L2 19L5 19L5 16Z" fill="#000000"/>
              </g>
            </svg>
          </div>
          <div>Nama Tamu</div>
          <button id="closeQrModalBtn" type="button" class="btn btn-secondary btn-sm mt-3">Tutup</button>
        </div>
      </div>
    </div>

    <!-- Modal RSVP -->
    <div class="modal fade" id="rsvpModal" tabindex="-1" role="dialog" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content p-4">
          <h5 class="text-center mb-3 font-accent">Konfirmasi Kehadiran</h5>
          <form id="rsvpForm">
            <div class="mb-2">
              <input type="text" class="form-control" placeholder="Nama Anda" required />
            </div>
            <div class="mb-2">
              <select class="form-control">
                <option value="Hadir">Hadir</option>
                <option value="Tidak Hadir">Tidak Hadir</option>
              </select>
            </div>
            <div class="mb-3">
              <textarea class="form-control" rows="3" placeholder="Ucapan & Doa"></textarea>
            </div>
            <button type="submit" class="btn btn-primary w-100 mb-2">Kirim</button>
            <button id="closeRsvpModalBtn" type="button" class="btn btn-secondary w-100">Batal</button>
          </form>
        </div>
      </div>
    </div>
  </main>

  <script src="../scripts/invitation.js"></script>
</body>
</html>
