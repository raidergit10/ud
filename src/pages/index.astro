---
import '../styles/global.css';

// Undangan Pernikahan — Fahrul & Ainun (Tema Bugis)
// Desain, background, warna & tata letak aset mengikuti referensi invite.digimo.id/tema-bugis.
// Semua gaya bersifat self-contained (tidak bergantung Tailwind) via blok <style> di bawah.
//
// LETAKKAN ASET DI /public/images/ dengan nama file asli dari zip:
//   Com-BUGIS-BG.webp, Bugis-Asset-1-Copy2-2048x344.webp, Bugis-Asset-1-Copy-2048x344.webp,
//   Bugis-Asset-3.webp, logo.webp, logonama.webp, animasilogo.webm,
//   dan foto "WhatsApp Image ..." (spasi di-encode %20).

const title = "Undangan Pernikahan — Fahrul & Ainun";
const description = "Undangan pernikahan Muhammad Fahrul Azali, S.IP & Ainun Ulfa, S.Kep., Ns — Sabtu, 08 Agustus 2026 di Kab. Majene, Sulawesi Barat.";

// URL situs diambil dari `site` di astro.config.mjs (cukup ganti domain di sana sekali).
const siteUrl = (Astro.site?.href ?? "https://undanganulfahrul.ijlalcode.my.id").replace(/\/$/, "");
const canonical = siteUrl + "/";
const ogImage = siteUrl + "/images/WhatsApp%20Image%202026-07-22%20at%2013.11.09.webp";

// Data terstruktur (Schema.org Event) — membantu Google & AI memahami acara ini.
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Event",
  name: "Pernikahan Muhammad Fahrul Azali & Ainun Ulfa",
  description,
  startDate: "2026-08-08T10:30:00+08:00",
  endDate: "2026-08-08T22:00:00+08:00",
  eventStatus: "https://schema.org/EventScheduled",
  eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
  image: [ogImage],
  url: canonical,
  location: {
    "@type": "Place",
    name: "Kediaman Mempelai (Baurung)",
    address: {
      "@type": "PostalAddress",
      streetAddress: "Baurung, Kec. Banggae Timur",
      addressLocality: "Majene",
      addressRegion: "Sulawesi Barat",
      postalCode: "91412",
      addressCountry: "ID",
    },
  },
  organizer: { "@type": "Person", name: "Fahrul & Ainun" },
};
---

<!DOCTYPE html>
<html lang="id" translate="no">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0" />
  <meta name="color-scheme" content="light only" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="undangan pernikahan, undangan digital, Fahrul dan Ainun, wedding invitation, Majene, Sulawesi Barat, pernikahan 2026, tema Bugis" />
  <meta name="author" content="Fahrul & Ainun" />
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
  <link rel="canonical" href={canonical} />
  <meta name="theme-color" content="#241a19" />
  <!-- Verifikasi Google Search Console lewat DNS (properti Domain di Cloudflare), jadi tidak perlu meta tag verifikasi di sini. -->
  <!-- Open Graph (WhatsApp, Facebook, dll.) -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Undangan Pernikahan Fahrul & Ainun" />
  <meta property="og:locale" content="id_ID" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:alt" content="Undangan Pernikahan Fahrul & Ainun" />
  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <!-- Data terstruktur Schema.org untuk Google & AI -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Great+Vibes&family=Marcellus&display=swap" />
  <!-- Favicon (logo UF) -->
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <!-- Lenis smooth scroll (ringan ~10KB, otomatis di-cache browser) -->
  <script src="https://cdn.jsdelivr.net/npm/lenis@1.1.20/dist/lenis.min.js"></script>
  <style>
:root{
  --bg:#241a19; --panel:rgba(20,12,12,.55); --panel-solid:#2a1e1d;
  --maroon:#96112A; --maroon-dark:#5A0A17; --red:#D90A11;
  --gold:#D7A916; --gold-lite:#F3CB51; --green:#3D9A62;
  --cream:#E8D3C3; --cream-lite:#FBF0DA; --tan:#C9A46A;
  --reveal-duration:1s; --reveal-ease:cubic-bezier(.22,.61,.36,1);
  --pad:clamp(20px,5vw,120px);
}
*{box-sizing:border-box}
html{-webkit-text-size-adjust:100%}
/* ===== Lenis smooth scroll ===== */
html.lenis,html.lenis body{height:auto}
.lenis.lenis-smooth{scroll-behavior:auto!important}
.lenis.lenis-smooth [data-lenis-prevent]{overscroll-behavior:contain}
.lenis.lenis-stopped{overflow:hidden}
body{
  margin:0;padding:0;font-family:"Marcellus",serif;color:var(--cream);
  overflow-x:hidden;-webkit-font-smoothing:antialiased;background:var(--bg);
}
/* Background sebagai layer terpisah: GPU-friendly & mulus dgn Lenis, tanpa jank 'fixed' di HP */
body::before{content:"";position:fixed;inset:0;z-index:-1;
  background:var(--bg) url('/images/Com-BUGIS-BG.webp') top center / cover no-repeat}
body.not-open,body.is-loading{overflow:hidden!important;height:100vh}
img{max-width:100%;display:block}
.font-accent{font-family:"Cormorant Garamond","Marcellus",serif;font-weight:600}
.font-latin{font-family:"Great Vibes",cursive}

#app{width:100%;max-width:1920px;margin:0 auto;position:relative;box-shadow:0 0 60px rgba(0,0,0,.6)}
ul.sections{list-style:none;margin:0;padding:0;display:flex;flex-direction:column}
.section{position:relative;width:100%;overflow:hidden;padding:clamp(56px,6vw,130px) var(--pad);
  background:rgba(18,10,10,.34);}
.inner{max-width:clamp(432px,64vw,1180px);margin:0 auto;text-align:center}

/* headings */
.eyebrow{font-size:13px;letter-spacing:4px;text-transform:uppercase;color:var(--gold-lite);margin-bottom:6px}
.h-script{font-family:"Great Vibes",cursive;color:var(--gold-lite);line-height:1.1}
.h-accent{font-family:"Cormorant Garamond",serif;font-weight:600;color:var(--gold-lite)}
.divider-img{width:100%;height:auto;margin:20px 0}
.text{font-size:14.5px;line-height:1.7;color:var(--cream)}
.muted{color:#cbb6a3}

/* buttons */
.btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;border:none;cursor:pointer;
  border-radius:8px;padding:11px 26px;font-size:14px;font-family:"Marcellus",serif;
  box-shadow:0 6px 16px rgba(0,0,0,.35);transition:transform .15s ease,background .2s ease}
.btn:active{transform:scale(.95)}
.btn-gold{background:var(--gold);color:var(--maroon-dark);font-weight:700}
.btn-gold:hover{background:#c39a13}
.btn-maroon{background:var(--maroon);color:var(--cream-lite)}
.btn-maroon:hover{background:#7a0d22}

/* ================= COVER ================= */
.cover{position:relative;min-height:100vh;display:flex;justify-content:center;align-items:stretch;padding:0;
  background:linear-gradient(rgba(11,5,5,.55),rgba(150,17,42,.72)), url('/images/WhatsApp%20Image%202026-07-22%20at%2013.11.09.webp');
  background-size:cover;background-position:center;background-attachment:scroll}
.cover .col{display:flex;flex-direction:column;justify-content:space-between;align-items:center;min-height:100vh;padding:0 var(--pad);width:100%;
  padding-bottom:clamp(72px,16.5vw,340px)}
.cover .strip{width:auto;margin-left:calc(-1 * var(--pad));margin-right:calc(-1 * var(--pad))}
.cover .strip img{width:100%;height:auto;display:block}
/* Ornamen Bugis bawah: dikunci menempel di dasar cover, full-bleed, tanpa celah & tidak ikut naik */
.cover .strip.bottom{position:absolute;left:0;right:0;bottom:0;width:100%;margin:0;z-index:2}
.cover .strip.bottom img{transform:scaleY(-1)}
/* Bugis border sebagai pembatas antar section (full-bleed kiri-kanan, tidak terpotong kecil) */
.secdiv{width:100%;line-height:0;font-size:0;margin:0}
.secdiv img{width:100%;height:auto;display:block}
.secdiv.flip img{transform:scaleY(-1)}
.fbleed{width:auto;margin-left:calc(-1 * var(--pad));margin-right:calc(-1 * var(--pad));margin-top:26px;margin-bottom:26px;line-height:0}
.fbleed img{width:100%;height:auto;display:block}
.fbleed.flip img{transform:scaleY(-1)}
.cover .title{font-family:"Great Vibes",cursive;font-size:60px;line-height:1.05;color:var(--cream-lite);text-shadow:0 2px 14px rgba(0,0,0,.4)}
.cover .date{font-size:14px;letter-spacing:1px;color:var(--gold-lite);margin-top:4px}
.guest-card{margin:0 auto 14px;max-width:260px;padding:12px;border-radius:10px;
  background:rgba(0,0,0,.28);border:1px solid rgba(243,203,81,.45)}
.guest-card .to{font-size:14px;color:var(--cream-lite);margin-bottom:4px}
.guest-card .name{font-weight:700;font-size:17px;color:var(--gold-lite);margin-bottom:2px}

/* ornaments */
.orn{width:84px;height:auto;margin:0 auto 12px;filter:drop-shadow(0 2px 6px rgba(0,0,0,.4))}
.house{width:150px;margin:6px auto 4px;filter:drop-shadow(0 6px 14px rgba(0,0,0,.5))}

/* mempelai */
.photo-round{width:200px;height:200px;border-radius:50%;overflow:hidden;margin:0 auto 16px;
  border:4px solid var(--gold);box-shadow:0 10px 24px rgba(0,0,0,.5)}
.photo-round img{width:100%;height:100%;object-fit:cover}
.name-big{color:var(--gold-lite);font-family:"Cormorant Garamond",serif;font-weight:700;font-size:27px;margin-bottom:4px}
.dengan{font-family:"Great Vibes",cursive;color:var(--gold);font-size:34px;margin:6px 0}

/* journey */
.photo-rect{width:100%;max-width:320px;margin:0 auto 16px;border-radius:10px;overflow:hidden;border:4px solid var(--gold);box-shadow:0 10px 24px rgba(0,0,0,.5)}
.photo-rect img{width:100%;height:auto}

/* date block */
.datebox{display:flex;align-items:center;justify-content:center;gap:16px;margin:8px 0}
.datebox .side{font-family:"Cormorant Garamond",serif;font-size:20px;color:var(--tan);line-height:1.1}
.datebox .day{padding:0 14px;border-left:2px solid var(--gold);border-right:2px solid var(--gold)}
.datebox .day .num{font-family:"Cormorant Garamond",serif;font-size:56px;line-height:1;color:var(--gold-lite)}
.chip{width:130px;margin:22px auto;height:auto}

/* countdown */
.countdown{display:flex;justify-content:center;gap:8px;max-width:300px;margin:0 auto 16px}
.cd-item{flex:1;max-width:68px;border-radius:10px;padding:10px 4px;background:var(--maroon);
  color:var(--cream-lite);border:1px solid rgba(215,169,22,.6);display:flex;flex-direction:column;align-items:center}
.cd-item .num{font-size:22px;font-weight:700;line-height:1.1}
.cd-item .lbl{font-size:12px}
.map-wrap{position:relative;width:100%;padding-bottom:56%;border-radius:10px;overflow:hidden;border:4px solid var(--gold);margin:0 auto 18px}
.map-wrap iframe{position:absolute;inset:0;width:100%;height:100%;border:0}

/* gallery */
.gallery{display:flex;gap:8px}
.gcol{flex:1;display:flex;flex-direction:column;gap:8px}
.gitem{width:100%;overflow:hidden;border-radius:6px;border:2px solid rgba(215,169,22,.7)}
.gitem img{width:100%;height:100%;object-fit:cover}
.h150{height:150px}.h220{height:220px}.h280{height:280px}

/* gift */
.gift-card{margin-top:14px;padding:22px;border-radius:10px;border:1px solid var(--gold);background:rgba(0,0,0,.3);text-align:left}
.bank-row{display:flex;align-items:center;gap:10px;margin-bottom:12px}
.bank-logo{width:80px;height:48px;border-radius:6px;background:#fff;color:#222;display:flex;align-items:center;justify-content:center;font-weight:700;font-family:Arial,sans-serif;font-size:14px;text-align:center;padding:0 4px}
.bank-num{font-weight:700;font-size:17px;color:var(--cream-lite)}

/* card panel */
.panel-quote{margin-top:8px;padding:16px 18px;border-radius:10px;background:rgba(0,0,0,.28);border:1px solid rgba(215,169,22,.35)}

/* reveal anim */
.animate{opacity:0;transition:opacity var(--reveal-duration) ease, transform var(--reveal-duration) var(--reveal-ease);will-change:opacity,transform}
.fadeInUp{transform:translate3d(0,24px,0)}
.fadeInDown{transform:translate3d(0,-24px,0)}
.fadeInLeft{transform:translate3d(-24px,0,0)}
.fadeInRight{transform:translate3d(24px,0,0)}
.zoomIn{transform:scale(.94)}
.animate.is-visible{opacity:1;transform:translate3d(0,0,0) scale(1)}

/* loader */
.loader{position:fixed;inset:0;z-index:99999;display:flex;justify-content:center;align-items:center;
  background:radial-gradient(120% 120% at 50% 0%, #3a2422 0%, #1c1312 100%);transition:opacity .6s ease,visibility .6s ease}
.loader.loaded{opacity:0;visibility:hidden;pointer-events:none}
.loader .box{width:82%;max-width:320px;text-align:center}
.loader .lt{font-family:"Great Vibes",cursive;font-size:44px;color:var(--gold-lite);margin-bottom:12px}
.ring{width:46px;height:46px;margin:0 auto 14px;border-radius:50%;border:3px solid rgba(215,169,22,.3);border-top-color:var(--gold-lite);animation:spin .9s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.bar{width:100%;max-width:220px;height:4px;margin:14px auto 0;background:rgba(215,169,22,.2);border-radius:99px;overflow:hidden}
.bar span{display:block;height:100%;width:0;background:var(--gold);border-radius:99px;transition:width .25s ease}

/* fabs */
.fabs{position:fixed;bottom:24px;right:20px;z-index:999;display:flex;flex-direction:column;align-items:end;gap:10px}
.fab{width:46px;height:46px;border-radius:50%;background:var(--maroon);color:var(--cream-lite);border:1px solid rgba(215,169,22,.5);
  display:flex;align-items:center;justify-content:center;box-shadow:0 6px 16px rgba(0,0,0,.4);cursor:pointer}
/* Tombol musik: garis miring hanya saat non-aktif (muted) */
#btnMusic{position:relative;overflow:hidden}
#btnMusic.muted::after{content:"";position:absolute;top:50%;left:50%;width:150%;height:2.5px;border-radius:2px;background:var(--cream-lite);box-shadow:0 0 0 1.5px var(--maroon);transform:translate(-50%,-50%) rotate(-45deg)}
.to-top{position:fixed;bottom:24px;left:20px;z-index:999;opacity:0;visibility:hidden;transform:translateY(16px) scale(.9);transition:.35s var(--reveal-ease)}
.to-top.show{opacity:1;visibility:visible;transform:none}

/* ===== intro video (tampil setelah preload) + cover top ===== */
.intro{position:fixed;inset:0;z-index:99997;background:#0b0505;display:flex;align-items:center;justify-content:center;
  opacity:0;visibility:hidden;
  transition:transform .9s var(--reveal-ease),opacity .5s ease,visibility .5s ease}
.intro.show{opacity:1;visibility:visible}
.intro.up{transform:translateY(-100%)}
.intro video{max-width:100%;max-height:100%;width:auto;height:auto;object-fit:contain}
.cover .col{padding-top:0}
.cover-top{width:100%}
.logonama{width:54%;max-width:200px;height:auto;margin:16px auto 0;filter:drop-shadow(0 4px 12px rgba(0,0,0,.55))}
.open-wrap{text-align:center;width:100%}

/* ===== Responsive 360px -> 1920px: full-bleed & konten membesar proporsional ===== */
.eyebrow{font-size:clamp(13px,1vw,22px)}
.text{font-size:clamp(14.5px,1.1vw,25px)!important;line-height:1.7}
.h-accent{font-size:clamp(28px,3vw,62px)!important}
.section .title{font-size:clamp(52px,6vw,120px)!important}
.name-big{font-size:clamp(25px,2.6vw,54px)!important}
.dengan{font-size:clamp(34px,3.4vw,72px)}
.cover .title{font-size:clamp(52px,7vw,150px)}
.cover .date{font-size:clamp(14px,1.2vw,28px)}
.guest-card{max-width:clamp(260px,32vw,540px)}
.guest-card .to{font-size:clamp(14px,1vw,22px)}
.guest-card .name{font-size:clamp(17px,1.4vw,30px)}
.btn{font-size:clamp(14px,1.05vw,24px);padding:clamp(11px,1vw,22px) clamp(26px,2.4vw,58px)}
.logonama{max-width:clamp(200px,22vw,440px)}
.photo-round{width:clamp(200px,22vw,440px)!important;height:clamp(200px,22vw,440px)!important}
.photo-rect{max-width:clamp(320px,42vw,780px)}
.datebox .day .num{font-size:clamp(56px,6vw,120px)}
.datebox .side{font-size:clamp(20px,2vw,40px)}
.countdown{max-width:clamp(300px,42vw,760px)}
.cd-item{max-width:none}
.cd-item .num{font-size:clamp(22px,2.2vw,48px)}
.cd-item .lbl{font-size:clamp(12px,1vw,22px)}
.bank-num{font-size:clamp(17px,1.4vw,30px)}
.gift-card{max-width:clamp(280px,64vw,780px);margin-left:auto;margin-right:auto}
.map-wrap{max-width:clamp(280px,64vw,900px);margin-left:auto;margin-right:auto}
.gallery{max-width:clamp(280px,66vw,1040px);margin:0 auto}
.h150{height:clamp(150px,16vw,300px)}
.h220{height:clamp(220px,23vw,440px)}
.h280{height:clamp(280px,30vw,560px)}

@media (prefers-reduced-motion: reduce){
  html{scroll-behavior:auto}
  .animate{opacity:1!important;transform:none!important;transition:none!important}
  .ring{animation:none!important}
}
@media (max-width:420px){
  .cover .title{font-size:52px}
  .photo-round{width:170px;height:170px}
}
</style>
</head>
<body class="not-open is-loading">


<!-- Loader -->
<div class="loader" id="loader">
  <div class="box">
    <div class="lt">Fahrul &amp; Ainun</div>
    <div class="ring"></div>
    <div style="font-size:15px;letter-spacing:1px"><span id="pct">0</span>%</div>
    <div style="font-size:12px;opacity:.7;margin-top:6px">Menyiapkan undangan…</div>
    <div class="bar"><span id="bar"></span></div>
  </div>
</div>

<!-- Intro Video: tampil setelah preload untuk merender & meng-cache semua aset -->
<div class="intro" id="intro">
  <video id="introVideo" muted playsinline preload="auto" poster="/images/logo.webp">
    <source src="/images/animasilogo.webm" type="video/webm" />
  </video>
</div>

<main id="app">
<ul class="sections">

  <!-- 1. COVER (tanpa animasi reveal — langsung tampil) -->
  <li class="cover">
    <div class="col">
      <div class="cover-top">
        <div class="strip top"><img src="/images/Bugis-Asset-1-Copy-2048x344.webp" alt="ornamen" /></div>
        <img class="logonama" src="/images/logonama.webp" alt="Fahrul &amp; Ainun" />
      </div>
      <div>
        <div class="eyebrow">The Wedding Of</div>
        <div class="title">Fahrul &amp; Ainun</div>
        <div class="date">Sabtu, 08 Agustus 2026</div>
      </div>
      <div style="width:100%">
        <div class="guest-card">
          <div class="to">Kepada Yth.<br />Bapak/Ibu/Saudara/i</div>
          <div class="name">Tamu Undangan</div>
          <div style="font-size:14px;color:var(--cream-lite)">di Tempat</div>
        </div>
        <div class="open-wrap"><button class="btn btn-gold" id="btnOpen">Buka Undangan</button></div>
      </div>
    </div>
    <!-- Ornamen Bugis dikunci di dasar cover (tidak ikut naik, tanpa celah) -->
    <div class="strip bottom"><img src="/images/Bugis-Asset-1-Copy-2048x344.webp" alt="ornamen" /></div>
  </li>

  <!-- 2. PEMBUKA & AYAT -->
  <li class="section" id="main">
    <div class="inner">
      <img class="orn animate zoomIn" src="/images/logo.webp" alt="logo" style="width:120px" />
      <div class="h-accent animate fadeInDown" style="font-size:30px;margin-bottom:14px">We&rsquo;re Getting Married</div>
      <div class="text animate fadeInDown" style="margin-bottom:8px">Assalamualaikum Warahmatullahi Wabarakatuh</div>
      <div class="text animate fadeInDown" style="margin-bottom:22px">Dengan memohon rahmat dan ridho Allah SWT yang telah menciptakan makhluk-Nya secara berpasang-pasangan, kami bermaksud menyelenggarakan pernikahan putra-putri kami:</div>
      <div class="name-big animate fadeInLeft" style="font-size:25px">Muhammad Fahrul Azali, S.IP</div>
      <div class="dengan animate zoomIn">&amp;</div>
      <div class="name-big animate fadeInRight" style="font-size:25px">Ainun Ulfa, S.Kep., Ns</div>
      <div class="fbleed animate fadeInUp"><img src="/images/Bugis-Asset-1-Copy-2048x344.webp" alt="pembatas" /></div>
      <div class="text animate fadeInUp" style="font-style:italic">&ldquo;Dan di antara tanda-tanda kekuasaan-Nya ialah Dia menciptakan untukmu istri-istri dari jenismu sendiri, supaya kamu cenderung dan merasa tenteram kepadanya, dan dijadikan-Nya di antaramu rasa kasih dan sayang.&rdquo;</div>
      <div class="text animate fadeInUp" style="margin-top:8px;color:var(--gold-lite)">(QS. Ar-Rum : 21)</div>
