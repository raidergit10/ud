---
import '../styles/global.css';

// Undangan Pernikahan — Fahrul & Ainun
// Versi Tailwind CSS: tanpa file invitation.css & invitation.js terpisah.
// Styling utama pakai utility Tailwind; keyframes/animasi khusus ada di blok
// <style> di bawah; seluruh logika interaktif ada di <script> di file ini.

const title = "Undangan Pernikahan — Fahrul & Ainun";
const description = "Undangan pernikahan Muhammad Fahrul Azali, S.IP & Ainun Ulfa, S.Kep., Ns — Sabtu, 08 Agustus 2026 di Pangali-ali, Kec. Banggae, Kab. Majene.";
const image = "/images/p2.jpg";

// Kelas tombol utama dipakai berulang
const btnPrimary = "inline-flex items-center justify-center gap-2 rounded-md bg-[#9F709A] px-5 py-2.5 text-sm text-white shadow-md transition hover:opacity-90 active:scale-95";
---

<!DOCTYPE html>
<html lang="id" class="notranslate" translate="no">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0" />
  <meta name="color-scheme" content="light only" />
  <meta name="format-detection" content="telephone=no" />
  <meta name="google" content="notranslate" />

  <title>{title}</title>
  <meta name="title" content={title} />
  <meta name="description" content={description} />

  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={image} />

  <link rel="icon" type="image/x-icon" href="/images/decor/flower-1.webp" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Marcellus&display=swap" />
</head>

<body class="text-[#604024]">
  <main id="app">
    <!-- Overlay untuk modal -->
    <div id="modalOverlay" class="hidden fixed inset-0 z-[1000] bg-black/50"></div>

    <!-- Loader / Preloader (Landing) -->
    <div id="loader" class="loader-wrapper">
      <div class="loader-box w-[82%] max-w-[320px] text-center text-[#604024]">
        <div class="loader-title font-latin text-[40px] leading-tight text-[#9F709A] mb-[18px]">Fahrul &amp; Ainun</div>
        <div class="loader-ring w-[46px] h-[46px] mx-auto mb-3.5 rounded-full border-[3px] border-[#9F709A]/25 border-t-[#9F709A]"></div>
        <div class="text-[15px] tracking-wide text-[#604024]"><span id="loaderPercent">0</span>%</div>
        <div class="mt-1.5 text-xs tracking-wide opacity-70">Menyiapkan undangan…</div>
        <div class="w-full max-w-[220px] h-1 mx-auto mt-4 bg-[#747254]/20 rounded-full overflow-hidden">
          <span id="loaderBar" class="loader-bar-fill block h-full w-0 bg-[#9F709A] rounded-full"></span>
        </div>
      </div>
    </div>

    <!-- Music Player -->
    <audio id="music" loop>
      <source src="https://assets.satumomen.com/musics/elliot-james-reay-i-think-they-call-this-love-lyrics-ql9vwz3kfqg.mp3" type="audio/mpeg" />
    </audio>

    <div id="satuMomen" data-guest="Nama Tamu" data-group="VIP">
      <div class="w-full">
        <ul class="list-none p-0 m-0 flex flex-col">

          <!-- Section 1: Cover -->
          <li class="relative w-full overflow-hidden flex justify-center items-center min-h-screen bg-cover bg-center bg-no-repeat" style="background-image:linear-gradient(rgba(96,64,36,0.45),rgba(96,64,36,0.6)),url('/images/p2.jpg');">
            <div class="max-w-[480px] w-full mx-auto h-full">
              <div class="pt-6 h-full w-full flex flex-col justify-center items-center pb-20 min-h-screen">
                <div class="mt-6 mb-auto text-center animate__animated animate__fadeInDown">
                  <div class="text-[14.4px] text-white">The Wedding Of</div>
                  <div class="font-latin text-[50px] leading-tight text-white">Fahrul &amp; Ainun</div>
                </div>
                <div class="w-full text-center mx-auto">
                  <div class="mx-auto w-full text-center mb-3 p-2 rounded-lg max-w-[240px] bg-white/40 animate__animated animate__zoomIn">
                    <div class="mb-1 text-[14px] text-white animate__animated animate__fadeInUp">Kepada Yth.<br />Bapak/Ibu/Saudara/i</div>
                    <div id="guestNameSlot" class="font-bold text-[16px] text-white mb-1 animate__animated animate__fadeInUp">Tamu Undangan</div>
                    <div id="groupNameSlot" class="text-[14.4px] text-white animate__animated animate__fadeInUp">di Tempat</div>
                  </div>
                  <button id="btnOpenInvitation" class={`${btnPrimary} animate__animated animate__fadeInUp`}>Open Invitation</button>
                </div>
              </div>
            </div>
          </li>

          <!-- Section 2: Pembuka & Ayat -->
          <li id="mainContent" class="relative w-full overflow-hidden flex justify-center items-center py-14 bg-[url('/images/bg2.webp')] bg-cover bg-center bg-no-repeat">
            <div class="max-w-[480px] w-full mx-auto px-6">
              <div class="w-full flex flex-col justify-center items-center">
                <div class="mb-2 text-center text-[14.4px] animate__animated animate__fadeInDown">Assalamualaikum Warahmatullahi Wabarakatuh</div>
                <div class="text-center mb-6 text-[14.4px] animate__animated animate__fadeInDown">
                  Maha Suci Allah SWT yang telah menciptakan hamba-Nya berpasang-pasangan.<br />Ya Allah, dengan memohon Rahmat dan Ridho-Mu, perkenankanlah kami menikahkan Putra-Putri kami:
                </div>
                <div class="text-center">
                  <div class="text-[#9F709A] text-[20px] font-accent animate__animated animate__fadeInLeft">Muhammad Fahrul Azali, S.IP</div>
                  <div class="text-[#9F709A] text-[24px] font-latin animate__animated animate__zoomIn">&amp;</div>
                  <div class="text-[#9F709A] text-[20px] font-accent animate__animated animate__fadeInRight">Ainun Ulfa, S.Kep., Ns</div>
                </div>

                <div class="wave-left my-3 mx-auto w-[20%] animate__animated animate__zoomIn">
                  <img src="/images/decor/flower-1.webp" alt="flower" class="w-full h-auto pointer-events-none" loading="lazy" decoding="async" />
                </div>

                <div class="text-center animate__animated animate__fadeInUp">
                  <div class="mb-3 text-[14.4px] italic">
                    Dan di antara tanda-tanda (kebesaran)-Nya ialah Dia menciptakan pasangan-pasangan untukmu dari jenismu sendiri, agar kamu cenderung dan merasa tenteram kepadanya, dan Dia menjadikan di antaramu rasa kasih dan sayang. Sungguh, pada yang demikian itu benar-benar terdapat tanda-tanda (kebesaran Allah) bagi kaum yang berpikir.
                  </div>
                  <div class="text-[14.4px]">(Ar-Rum : 21)</div>
                </div>
              </div>
            </div>
          </li>

          <!-- Section 3: Mempelai -->
          <li class="relative w-full overflow-hidden flex justify-center items-center py-14 bg-[url('/images/bg2.webp')] bg-cover bg-center bg-no-repeat">
            <div class="max-w-[480px] w-full mx-auto px-6 relative">
              <img src="/images/decor/flower-motif.webp" class="pointer-events-none absolute inset-0 w-full" alt="flower motif" loading="lazy" decoding="async" />
              <div class="w-full flex flex-col justify-center items-center relative">
                <div class="relative mb-6 mx-auto w-[70%] animate__animated animate__zoomIn">
                  <div class="absolute w-1/2 left-[-27%] top-[-12%] wave-left">
                    <img src="/images/decor/flower-2.webp" alt="flower" class="w-full h-auto pointer-events-none origin-bottom" loading="lazy" decoding="async" />
                  </div>
                  <div class="absolute w-1/2 right-[-27%] bottom-[-3%] wave-right">
                    <img src="/images/decor/flower-3.webp" alt="flower" class="w-full h-auto pointer-events-none origin-bottom" loading="lazy" decoding="async" />
                  </div>
                  <div class="w-full relative overflow-hidden rounded-lg h-[220px] border-4 border-[#747254]">
                    <img src="/images/p3.jpg" alt="Fahrul & Ainun" class="w-full h-full object-cover" loading="lazy" decoding="async" />
                  </div>
                </div>
                <div class="text-center mb-6 relative">
                  <div class="text-[#9F709A] text-[20px] font-accent mb-2 animate__animated animate__fadeInLeft">Muhammad Fahrul Azali, S.IP</div>
                  <div class="text-[14.4px] animate__animated animate__zoomIn">Putra ke-dua dari<br />Bapak Azali Mudjahid Pawelloi, S.E &amp;<br />Ibu Nursaida Said</div>
                </div>
                <div class="text-center relative">
                  <div class="text-[#9F709A] text-[20px] font-accent mb-2 animate__animated animate__fadeInRight">Ainun Ulfa, S.Kep., Ns</div>
                  <div class="text-[14.4px] animate__animated animate__zoomIn">Putri pertama dari<br />Bapak Sirajuddin, S.Ag &amp;<br />Ibu Maryam, S.Ag</div>
                </div>
              </div>
            </div>
          </li>

          <!-- Section 4: Akad Nikah & Duduk Bersila -->
          <li class="relative w-full overflow-hidden flex justify-center items-center py-14 bg-[url('/images/bg2.webp')] bg-cover bg-center bg-no-repeat">
            <div class="max-w-[480px] w-full mx-auto px-6 relative">
              <div class="relative w-full flex flex-col justify-center items-center">
                <div class="absolute w-[35%] left-[-20%] top-[-3%] wave-left">
                  <img src="/images/decor/flower-6.webp" alt="flower" class="w-full h-auto pointer-events-none origin-bottom" loading="lazy" decoding="async" />
                </div>
                <div class="absolute w-[35%] right-[-20%] bottom-[-3%] -scale-x-100 wave-left">
                  <img src="/images/decor/flower-6.webp" alt="flower" class="w-full h-auto pointer-events-none origin-bottom" loading="lazy" decoding="async" />
                </div>
                <div class="text-center">
                  <div class="text-[16px] mb-3 animate__animated animate__fadeInDown">Sabtu, 08 Agustus 2026</div>
                  <div>
                    <div class="text-[#9F709A] text-[34px] font-accent animate__animated animate__fadeInLeft">Akad Nikah</div>
                    <div class="text-[14.4px] animate__animated animate__fadeInDown">Pukul 10.30 WITA - Selesai</div>
                    <div class="text-[14.4px] animate__animated animate__fadeInDown">di Kediaman Mempelai Wanita</div>
                  </div>
                  <div class="my-3 mx-auto w-[30%] animate__animated animate__zoomIn">
                    <img src="/images/decor/flower-4.webp" alt="flower" class="w-full h-auto pointer-events-none" loading="lazy" decoding="async" />
                  </div>
                  <div>
                    <div class="text-[#9F709A] text-[34px] font-accent animate__animated animate__fadeInRight">Duduk Bersila</div>
                    <div class="text-[14.4px] animate__animated animate__fadeInUp">Pukul 13.00 WITA - Selesai</div>
                    <div class="text-[14.4px] animate__animated animate__fadeInUp">di Kediaman Mempelai Pria</div>
                  </div>
                </div>
              </div>
            </div>
          </li>

          <!-- Section 5: Waktu Acara (Countdown) & Lokasi Acara (Maps) -->
          <li class="relative w-full overflow-hidden flex justify-center items-center py-14 bg-[url('/images/bg2.webp')] bg-cover bg-center bg-no-repeat">
            <div class="max-w-[480px] w-full mx-auto px-6 relative">
              <div class="relative w-full flex flex-col justify-center items-center pb-[160px]">
                <div class="absolute w-[35%] left-[-20%] top-[-3%] wave-left">
                  <img src="/images/decor/flower-6.webp" alt="flower" class="w-full h-auto pointer-events-none origin-bottom" loading="lazy" decoding="async" />
                </div>
                <div class="absolute w-[35%] right-[-20%] bottom-[20%] -scale-x-100 wave-right">
                  <img src="/images/decor/flower-6.webp" alt="flower" class="w-full h-auto pointer-events-none origin-bottom" loading="lazy" decoding="async" />
                </div>
                <div class="absolute left-[-30px] right-[-30px] bottom-[-30px] w-[calc(100%+60px)] animate__animated animate__fadeInUp">
                  <img src="/images/decor/flower-bm.webp" alt="motif" class="w-full h-auto pointer-events-none" loading="lazy" decoding="async" />
                </div>
                <div class="w-full relative">
                  <div class="mb-6 text-center text-[#747254] text-[32px] font-accent animate__animated animate__fadeInLeft">Waktu Acara</div>
                  <div class="countdown-wrapper mx-auto mb-3 w-full max-w-[280px] animate__animated animate__fadeInUp" data-datetime="2026-08-08T10:30">
                    <div class="countdown flex justify-center items-stretch gap-2 text-center">
                      <div class="countdown-item day flex-1 max-w-[64px] rounded-lg py-2 px-1 bg-[#9F709A] text-white flex flex-col items-center justify-center">
                        <div class="number text-[22px] font-bold leading-tight">00</div>
                        <div class="text text-xs">Hari</div>
                      </div>
                      <div class="countdown-item hour flex-1 max-w-[64px] rounded-lg py-2 px-1 bg-[#9F709A] text-white flex flex-col items-center justify-center">
                        <div class="number text-[22px] font-bold leading-tight">00</div>
                        <div class="text text-xs">Jam</div>
                      </div>
                      <div class="countdown-item minute flex-1 max-w-[64px] rounded-lg py-2 px-1 bg-[#9F709A] text-white flex flex-col items-center justify-center">
                        <div class="number text-[22px] font-bold leading-tight">00</div>
                        <div class="text text-xs">Menit</div>
                      </div>
                      <div class="countdown-item second flex-1 max-w-[64px] rounded-lg py-2 px-1 bg-[#9F709A] text-white flex flex-col items-center justify-center">
                        <div class="number text-[22px] font-bold leading-tight">00</div>
                        <div class="text text-xs">Detik</div>
                      </div>
                    </div>
                  </div>
                  <div class="text-center mb-12">
                    <a href="https://calendar.google.com/calendar/u/0/r/eventedit?text=Pernikahan%20Fahrul%20%26%20Ainun&amp;dates=20260808T023000Z%2F20260808T060000Z&amp;details=&amp;location=Jl.%20Ammana%20Wewang%20No.%2014%20Pangali-ali%2C%20Kec.%20Banggae%2C%20Kab.%20Majene" class={`${btnPrimary} mx-auto max-w-[200px] animate__animated animate__fadeInUp`} target="_blank" rel="noreferrer noopener">Tambahkan ke Kalender</a>
                  </div>
                  <div>
                    <div class="mb-6 text-center text-[#747254] text-[32px] font-accent animate__animated animate__fadeInLeft">Lokasi Acara</div>
                    <div class="relative w-full mx-auto mb-5 overflow-hidden rounded-[10px] border-4 border-[#9F709A] pb-[53%] animate__animated animate__zoomIn">
                      <iframe title="Lokasi Acara Pernikahan Fahrul & Ainun" class="absolute inset-0 w-full h-full border-0" allowfullscreen loading="lazy" referrerpolicy="strict-origin-when-cross-origin" src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1991.1050960627044!2d118.99214153072066!3d-3.538905928279302!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2d94bf0c0450c3e5%3A0x619d181cc85d379c!2sFX6V%2BC72%2C%20Baurung%2C%20Kec.%20Banggae%20Tim.%2C%20Kabupaten%20Majene%2C%20Sulawesi%20Barat%2091412!5e0!3m2!1sid!2sid!4v1784711004114!5m2!1sid!2sid"></iframe>
                    </div>
                    <div class="text-center animate__animated animate__fadeInUp">
                      <div class="mb-3 text-[14px]">Jl. Ammana Wewang No. 14 Pangali-ali,<br />Kec. Banggae, Kab. Majene, Sulawesi Barat</div>
                      <a href="https://maps.app.goo.gl/u63dUAmLEaczRiEa9" class={`${btnPrimary} mx-auto max-w-[200px] animate__animated animate__fadeInUp`} target="_blank" rel="noreferrer noopener">Buka Google Maps</a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </li>

          <!-- Section 6: Galeri -->
          <li class="relative w-full overflow-hidden flex justify-center items-center py-14 bg-[url('/images/bg2.webp')] bg-cover bg-center bg-no-repeat">
            <div class="max-w-[480px] w-full mx-auto px-6">
              <div class="w-full">
                <div class="text-center mb-6 text-[#9F709A] animate__animated animate__fadeInDown">
                  <div class="text-[32px] font-accent">Galeri</div>
                </div>
                <div class="flex gap-2">
                  <div class="flex-1 flex flex-col gap-2">
                    <div class="overflow-hidden w-full h-[150px] animate__animated animate__zoomIn"><img src="/images/p1.jpg" class="w-full h-full object-cover" alt="gallery-1" loading="lazy" decoding="async" /></div>
                    <div class="overflow-hidden w-full h-[280px] animate__animated animate__zoomIn"><img src="/images/p2.jpg" class="w-full h-full object-cover" alt="gallery-2" loading="lazy" decoding="async" /></div>
                    <div class="overflow-hidden w-full h-[220px] animate__animated animate__zoomIn"><img src="/images/p3.jpg" class="w-full h-full object-cover" alt="gallery-3" loading="lazy" decoding="async" /></div>
                  </div>
                  <div class="flex-1 flex flex-col gap-2">
                    <div class="overflow-hidden w-full h-[280px] animate__animated animate__zoomIn"><img src="/images/p3.jpg" class="w-full h-full object-cover" alt="gallery-4" loading="lazy" decoding="async" /></div>
                    <div class="overflow-hidden w-full h-[150px] animate__animated animate__zoomIn"><img src="/images/p1.jpg" class="w-full h-full object-cover" alt="gallery-5" loading="lazy" decoding="async" /></div>
                    <div class="overflow-hidden w-full h-[220px] animate__animated animate__zoomIn"><img src="/images/p2.jpg" class="w-full h-full object-cover" alt="gallery-6" loading="lazy" decoding="async" /></div>
                  </div>
                </div>
              </div>
            </div>
          </li>

          <!-- Section 7: RSVP -->
          <li class="relative w-full overflow-hidden flex justify-center items-center py-14 bg-[url('/images/bg2.webp')] bg-cover bg-center bg-no-repeat">
            <div class="max-w-[480px] w-full mx-auto px-6">
              <div class="w-full">
                <div class="animate__animated animate__fadeInRight">
                  <div class="w-[248px] h-[195px] mx-auto overflow-hidden border-4 border-[#747254]" style="transform:translate(15px,24px) rotate(356deg);">
                    <img src="/images/p1.jpg" class="w-full h-full object-cover" alt="Fahrul & Ainun" loading="lazy" decoding="async" />
                  </div>
                </div>
                <div class="animate__animated animate__fadeInLeft">
                  <div class="w-[248px] h-[195px] mx-auto overflow-hidden mb-5 border-4 border-[#747254]" style="transform:translate(-7px,0px) rotate(2deg);">
                    <img src="/images/p3.jpg" class="w-full h-full object-cover" alt="Fahrul & Ainun" loading="lazy" decoding="async" />
                  </div>
                </div>
                <div class="text-center">
                  <div class="mb-6 text-[14.4px] animate__animated animate__fadeInUp">Kirim ucapan untuk mempelai<br />dan konfirmasi kehadiran</div>
                  <button id="btnOpenRsvpModal" class={`${btnPrimary} mb-6 animate__animated animate__fadeInUp`}>Kirim Ucapan RSVP</button>
                </div>
              </div>
            </div>
          </li>

          <!-- Section 8: Gift / Hadiah -->
          <li class="relative w-full overflow-hidden flex justify-center items-center py-14 bg-[url('/images/bg2.webp')] bg-cover bg-center bg-no-repeat">
            <div class="max-w-[480px] w-full mx-auto px-6">
              <div class="w-full text-center">
                <div class="mx-auto w-[30%] animate__animated animate__zoomIn">
                  <img src="/images/decor/gift-icon.webp" alt="gift" class="w-full h-auto" loading="lazy" decoding="async" />
                </div>
                <div class="mb-6 text-[14.4px] animate__animated animate__fadeInDown">Terima kasih telah menambah semangat kegembiraan pernikahan kami dengan kehadiran dan hadiah indah Anda.</div>
                <div class="mt-3 p-6 rounded border border-[#747254] bg-white/60">
                  <div class="animate__animated animate__zoomIn">
                    <div class="mx-auto max-w-[280px]">
                      <div class="flex items-center mb-3">
                        <div class="w-[80px] h-[50px] overflow-hidden bg-white rounded">
                          <img src="/images/bank/bca.webp" class="w-full h-full object-contain" alt="BCA" loading="lazy" decoding="async" />
                        </div>
                        <div class="text-left pl-2">
                          <div class="font-bold text-lg mb-0">1234567890</div>
                          <div class="text-[14.4px]">BCA : a.n. Muhammad Fahrul Azali</div>
                        </div>
                      </div>
                      <div class="flex items-center">
                        <div class="w-[80px] h-[50px] overflow-hidden bg-white rounded">
                          <img src="/images/bank/bni.webp" class="w-full h-full object-contain" alt="BNI" loading="lazy" decoding="async" />
                        </div>
                        <div class="text-left pl-2">
                          <div class="font-bold text-lg mb-0">1234567890</div>
                          <div class="text-[14.4px]">BNI : a.n. Ainun Ulfa</div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="mt-3 p-6 rounded border border-[#747254] bg-white/60">
                  <div class="text-center mb-2 animate__animated animate__zoomIn">
                    <div class="font-bold text-lg text-[#9F709A] mb-2 font-accent">Kirim Hadiah</div>
                    <div class="mb-0">Anda dapat mengirim kado ke:<br />Jl. Ammana Wewang No. 14 Pangali-ali, Kec. Banggae, Kab. Majene</div>
                  </div>
                </div>
              </div>
            </div>
          </li>

          <!-- Section 9: Penutup -->
          <li class="relative w-full overflow-hidden flex justify-center items-center py-14 bg-[url('/images/bg2.webp')] bg-cover bg-center bg-no-repeat">
            <div class="max-w-[480px] w-full mx-auto px-6">
              <div class="relative flex flex-col justify-center w-full">
                <div class="absolute w-[35%] left-[-14%] bottom-[40%] wave-left">
                  <img src="/images/decor/flower-5.webp" alt="flower" class="w-full h-auto pointer-events-none origin-bottom" loading="lazy" decoding="async" />
                </div>
                <div class="absolute w-[35%] right-[-14%] bottom-[40%] -scale-x-100 wave-left">
                  <img src="/images/decor/flower-5.webp" alt="flower" class="w-full h-auto pointer-events-none origin-bottom" loading="lazy" decoding="async" />
                </div>
                <div class="absolute left-[-30px] right-[-30px] bottom-[-30px] w-[calc(100%+60px)] animate__animated animate__fadeInUp">
                  <img src="/images/decor/building-motif.webp" alt="motif" class="w-full h-auto pointer-events-none" loading="lazy" decoding="async" />
                </div>
                <div class="relative">
                  <div class="w-full text-center">
                    <div class="mb-2 text-[14.4px] animate__animated animate__fadeInDown">Merupakan suatu kehormatan dan<br />kebahagiaan bagi kami apabila<br />Bapak/Ibu/Saudara/i berkenan hadir<br />untuk memberikan do’a restu.</div>
                    <div class="mb-6 text-[14.4px] animate__animated animate__fadeInDown">Atas kehadiran dan do’a restunya<br />kami ucapkan terima kasih.</div>
                    <div class="mb-2 animate__animated animate__fadeInDown">Kami yang berbahagia<br /></div>
                    <div class="text-center">
                      <div class="text-[#9F709A] text-[32px] font-accent animate__animated animate__fadeInLeft">Fahrul</div>
                      <div class="text-[#9F709A] text-[24px] font-latin animate__animated animate__zoomIn">&amp;</div>
                      <div class="text-[#9F709A] text-[32px] font-accent animate__animated animate__fadeInRight">Ainun</div>
                    </div>
                    <div class="mt-3 text-[13px] animate__animated animate__fadeInUp">Kel. Bapak Azali Mudjahid Pawelloi, S.E<br />&amp; Ibu Nursaida Said</div>
                  </div>
                </div>
              </div>
            </div>
          </li>

        </ul>
      </div>
    </div>

    <!-- Floating Action Buttons -->
    <div class="fixed bottom-6 right-5 z-[999] flex flex-col items-end">
      <button id="btnQrModal" class="w-[46px] h-[46px] rounded-full bg-[#9F709A] text-white flex items-center justify-center shadow-lg mt-2.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 256 256">
          <rect x="40" y="40" width="80" height="80" rx="16"></rect>
          <rect x="40" y="136" width="80" height="80" rx="16"></rect>
          <rect x="136" y="40" width="80" height="80" rx="16"></rect>
        </svg>
      </button>
      <button id="btnMusic" class="w-[46px] h-[46px] rounded-full bg-[#9F709A] text-white flex items-center justify-center shadow-lg mt-2.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 256 256">
          <path d="M184,152V104a8,8,0,0,1,16,0v48a8,8,0,0,1-16,0Zm40-72a8,8,0,0,0-8,8v80a8,8,0,0,0,16,0V88A8,8,0,0,0,224,80ZM53.92,34.62A8,8,0,1,0,42.08,45.38L73.55,80H32A16,16,0,0,0,16,96v64a16,16,0,0,0,16,16H77.25l69.84,54.31A8,8,0,0,0,160,224V175.09l42.08,46.29a8,8,0,1,0,11.84-10.76Zm92.16,77.59A8,8,0,0,0,160,106.83V32a8,8,0,0,0-12.91-6.31l-39.85,31a8,8,0,0,0-1,11.7Z"></path>
        </svg>
      </button>
    </div>

    <!-- Tombol Kembali ke Atas -->
    <button id="btnBackToTop" class="btn-to-top fixed bottom-6 left-5 z-[999] w-[46px] h-[46px] rounded-full bg-[#9F709A] text-white flex items-center justify-center shadow-lg" aria-label="Kembali ke atas">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
      </svg>
