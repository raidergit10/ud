<!-- Musik latar (ikut di-preload penuh saat loading) -->
<audio id="bgm" src="/musics/song.mp3" loop preload="auto"></audio>
<div class="fabs">
  <div class="fab" id="btnMusic" title="Musik">&#9835;</div>
</div>
<div class="to-top" id="toTop"><div class="fab">&#8593;</div></div>

<script is:inline>
(function(){
  var reduce=window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var loader=document.getElementById('loader');
  var intro=document.getElementById('intro');
  var video=document.getElementById('introVideo');
  var pct=document.getElementById('pct');var bar=document.getElementById('bar');
  var bgm=document.getElementById('bgm');
  document.body.classList.add('is-loading','not-open');

  /* ===== Lenis: dibuat sekarang, scroll dikunci sampai "Buka Undangan" ditekan ===== */
  var lenis=null;
  function initLenis(){
    if(reduce||typeof Lenis==='undefined')return;
    lenis=new Lenis({lerp:0.1,smoothWheel:true,wheelMultiplier:1,touchMultiplier:1.6});
    function raf(t){lenis.raf(t);requestAnimationFrame(raf);}
    requestAnimationFrame(raf);
    lenis.stop();
  }
  function goTo(target){
    if(lenis){lenis.scrollTo(target,{duration:1.4});return;}
    if(typeof target==='number'){window.scrollTo({top:target,behavior:reduce?'auto':'smooth'});return;}
    var el=document.querySelector(target);if(el)el.scrollIntoView({behavior:reduce?'auto':'smooth'});
  }

  /* ===== PRELOAD SEMUA ASET (gambar + background CSS + video + musik + font) ===== */
  var imgs=[].slice.call(document.querySelectorAll('img[src]')).map(function(i){return i.getAttribute('src');});
  imgs.push('/images/Com-BUGIS-BG.webp');                        // background body (dari CSS, tak ada tag <img>)
  imgs=imgs.filter(function(v,i,a){return a.indexOf(v)===i;});   // buang duplikat
  var total=imgs.length + 3 /* video + audio + font */, loaded=0;
  function upd(){var p=Math.min(100,Math.round(loaded/total*100));if(pct)pct.textContent=p;if(bar)bar.style.width=p+'%';}
  function bump(){loaded++;upd();}
  function one(u){return new Promise(function(res){var im=new Image();im.onload=im.onerror=function(){bump();res();};im.src=u;});}
  function preloadMedia(el){return new Promise(function(res){
    var done=false,fin=function(){if(done)return;done=true;bump();res();};
    try{ if(el){ el.load();
      el.addEventListener('canplaythrough',fin,{once:true});
      el.addEventListener('error',fin,{once:true});
      setTimeout(fin,9000);
    } else fin(); }catch(e){ fin(); }
  });}
  function preloadFonts(){return new Promise(function(res){
    var done=false,fin=function(){if(done)return;done=true;bump();res();};
    try{ if(document.fonts&&document.fonts.ready){document.fonts.ready.then(fin);setTimeout(fin,6000);} else fin(); }catch(e){ fin(); }
  });}
  var started=false;
  function startIntro(){ if(started)return;started=true;
    loaded=total;upd();
    document.body.classList.remove('is-loading');
    if(loader){loader.classList.add('loaded');setTimeout(function(){loader.remove();},900);}
    if(!intro||!video||reduce){ finishIntro(); return; }
    intro.classList.add('show');
    var ended=false;
    var end=function(){ if(ended)return;ended=true; finishIntro(); };
    video.addEventListener('ended',end,{once:true});
    var dur=(isFinite(video.duration)&&video.duration>0)?video.duration:10;
    setTimeout(end,(dur+1.5)*1000);
    var pr=video.play();
    if(pr&&pr.catch){ pr.catch(function(){ setTimeout(end,10000); }); }
  }
  function finishIntro(){
    if(intro){ intro.classList.add('up'); setTimeout(function(){ intro.remove(); },1000); }
    initReveal();
    introDone=true;
    playMusic(); // coba putar musik otomatis begitu masuk halaman pembuka (setelah video)
  }
  Promise.all(imgs.map(one).concat([preloadMedia(video),preloadMedia(bgm),preloadFonts()])).then(function(){ setTimeout(startIntro,400); });
  setTimeout(startIntro,20000); // safety net (total aset ~5.5MB)
  upd();
  initLenis();
  var revInit=false;
  function initReveal(){if(revInit)return;revInit=true;var els=document.querySelectorAll('.animate');
    if(reduce||!('IntersectionObserver' in window)){els.forEach(function(e){e.classList.add('is-visible');});return;}
    var ob=new IntersectionObserver(function(en,o){en.forEach(function(t){if(t.isIntersecting){t.target.classList.add('is-visible');o.unobserve(t.target);}});},{threshold:.12,rootMargin:'0px 0px -40px 0px'});
    els.forEach(function(e){ob.observe(e);});}
  /* ===== Buka undangan: lepas kunci scroll, mulai Lenis, putar musik ===== */
  var playing=false;
  function syncMusic(){var b=document.getElementById('btnMusic');if(b){b.style.opacity=playing?'1':'.7';b.classList.toggle('muted',!playing);}}
  function playMusic(){if(!bgm)return;var pr=bgm.play();if(pr&&pr.then){pr.then(function(){playing=true;syncMusic();}).catch(function(){});}}
  document.getElementById('btnOpen').addEventListener('click',function(){
    document.body.classList.remove('not-open');
    if(lenis)lenis.start();
    goTo('#main');
    playMusic();
  });
  var toTop=document.getElementById('toTop');
  function onScroll(y){toTop.classList.toggle('show',(y||0)>350);}
  if(lenis){lenis.on('scroll',function(e){onScroll(e.scroll);});}
  window.addEventListener('scroll',function(){onScroll(window.scrollY);},{passive:true});
  toTop.addEventListener('click',function(){goTo(0);});
  document.getElementById('btnMusic').addEventListener('click',function(){
    if(!bgm)return;
    if(playing){bgm.pause();playing=false;syncMusic();}
    else{var pr=bgm.play();if(pr&&pr.then){pr.then(function(){playing=true;syncMusic();}).catch(function(){});}}
  });
  syncMusic();
  // Fallback: jika browser memblokir autoplay, mulai musik pada sentuhan/interaksi PERTAMA user (setelah video intro).
  // Hanya sekali: setelah itu kendali sepenuhnya ada di tombol musik (kalau user mematikan, tidak dinyalakan ulang).
  var introDone=false, kicked=false;
  function kickMusic(){ if(introDone&&!kicked){ kicked=true; playMusic(); } }
  ['pointerdown','touchstart','click','keydown','scroll','wheel'].forEach(function(ev){
    window.addEventListener(ev,kickMusic,{passive:true});
  });
  var cd=document.getElementById('cd');
  if(cd){var tgt=new Date(cd.dataset.datetime).getTime();var p=function(n){return String(n).padStart(2,'0');};
    function tick(){var df=tgt-Date.now();if(isNaN(df)||df<0)df=0;
      document.getElementById('d').textContent=p(Math.floor(df/864e5));
      document.getElementById('h').textContent=p(Math.floor(df%864e5/36e5));
      document.getElementById('m').textContent=p(Math.floor(df%36e5/6e4));
      document.getElementById('s').textContent=p(Math.floor(df%6e4/1e3));}
    tick();setInterval(tick,1000);}
})();
</script>

