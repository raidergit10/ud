<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Marcellus&display=swap');

  :root {
    --inv-bg: #ded7c7;
    --inv-base: #604024;
    --inv-accent: #9F709A;
    --inv-border: #747254;
    --menu-bg: #fffff9;
    --menu-inactive: #747254;
    --menu-active: #9F709A;
    --btn-color: #ffffff;
    --font-base: "Marcellus", serif;
    --font-accent: "Against", sans-serif;
    --font-latin: "English111 Vivace BT", cursive;
  }

  @keyframes wave-left {
    0% { transform: rotate(-3deg); }
    100% { transform: rotate(4deg); }
  }

  @keyframes wave-right {
    0% { transform: rotate(3deg); }
    100% { transform: rotate(-4deg); }
  }

  .wave-left img {
    animation: wave-left 4s ease-in-out infinite alternate;
  }

  .wave-right img {
    animation: wave-right 4s ease-in-out infinite alternate;
  }

  #YTMusic {
    display: block;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const audio = document.getElementById('music') as HTMLAudioElement;
    const musicBtn = document.getElementById('btnMusic');
    
    if (musicBtn && audio) {
      musicBtn.addEventListener('click', () => {
        if (audio.paused) {
          audio.play();
        } else {
          audio.pause();
        }
      });
    }

    const notSupportModal = document.getElementById('notSupport');
    const loader = document.getElementById('loader');
    
    if (navigator.userAgent.indexOf("UCBrowser") !== -1 || 
        navigator.userAgent.indexOf("MiuiBrowser") !== -1 || 
        navigator.userAgent.indexOf("OppoBrowser") !== -1) {
      if (notSupportModal) notSupportModal.classList.add('show');
      if (loader) loader.style.display = "none";
    }

    const closeNotSupportBtn = document.getElementById('closeNotSupportBtn');
    if (closeNotSupportBtn && notSupportModal) {
      closeNotSupportBtn.addEventListener('click', () => {
        notSupportModal.classList.remove('show');
      });
    }
  });
</script>